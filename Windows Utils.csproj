<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <MSBuildWarningsAsMessages>MSB3277</MSBuildWarningsAsMessages>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>net10.0-windows7.0</TargetFramework>
    <RootNamespace>SuchByte.WindowsUtils</RootNamespace>
    <UseWindowsForms>true</UseWindowsForms>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <Authors>Macro Deck</Authors>
    <Company>Macro Deck</Company>
    <AssemblyVersion>1.6.5.0</AssemblyVersion>
    <FileVersion>1.6.5.0</FileVersion>
    <!--
      版本号格式：1.6.5-bYYMMDDHHMM（SemVer 2.0 预发布版本）。
      每次构建动态生成，便于在 Macro Deck 中区分构建版本。
      AssemblyVersion / FileVersion 仍用纯数字四段式，避免破坏依赖该格式的工具。
    -->
    <VersionBase>1.6.5</VersionBase>
    <BuildTimestamp>$([System.DateTime]::Now.ToString("yyMMddHHmm"))</BuildTimestamp>
    <Version>$(VersionBase)-b$(BuildTimestamp)</Version>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Platforms>AnyCPU;x64</Platforms>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\Languages\*" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\Languages\*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="H.InputSimulator" Version="1.4.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <!--
    Designer 专用依赖：
    Macro Deck 2.dll 内嵌了 Sentry 的 source generator 代码（Sentry.Generated.BuildPropertyInitializer），
    在 Macro Deck 2.dll 加载时通过 <Module>.cctor 立即触发对 Sentry.dll 的真实加载。

    实现：
      1. PackageReference + IncludeAssets="none" — 让 NuGet 把 Sentry 6.6.0 还原到全局缓存，但不暴露资产给项目；
      2. <Reference> 指向缓存中的 Sentry.dll — 与 Macro Deck 2.dll 同样以 type:"reference" 形式进 deps.json，
         Designer Server 会按 bin/Debug 物理位置加载，绕开 NuGet 路径解析。
      3. Private 按配置控制：Debug 复制到 bin（供 Designer），Release/publish 不复制（运行时主程序提供）。
  -->
  <ItemGroup>
    <PackageReference Include="Sentry" Version="6.6.0" IncludeAssets="none" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup Condition="Exists('$(NuGetPackageRoot)sentry\6.6.0\lib\net10.0\Sentry.dll')">
    <Reference Include="Sentry">
      <HintPath>$(NuGetPackageRoot)sentry\6.6.0\lib\net10.0\Sentry.dll</HintPath>
      <Private Condition="'$(Configuration)' == 'Debug'">true</Private>
      <Private Condition="'$(Configuration)' != 'Debug'">false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Macro Deck 2">
      <HintPath Condition="Exists('C:\Program Files\Macro Deck\Macro Deck 2.dll')">C:\Program Files\Macro Deck\Macro Deck 2.dll</HintPath>
      <HintPath Condition="!Exists('C:\Program Files\Macro Deck\Macro Deck 2.dll')">libs\Macro Deck 2.dll</HintPath>
      <!-- Debug 下复制到 bin 供 WinForms Designer Server 反射加载基类；Release/publish 保持干净 -->
      <Private Condition="'$(Configuration)' == 'Debug'">true</Private>
      <Private Condition="'$(Configuration)' != 'Debug'">false</Private>
      <EmbedInteropTypes>false</EmbedInteropTypes>
    </Reference>
  </ItemGroup>

  <!--
    Macro Deck 安装目录探测（HintPath + Designer fallback 都会用到）。
  -->
  <PropertyGroup>
    <MacroDeckInstallDir Condition="Exists('C:\Program Files\Macro Deck\Macro Deck 2.dll')">C:\Program Files\Macro Deck\</MacroDeckInstallDir>
  </PropertyGroup>

  <ItemGroup>
    <Compile Update="Properties\Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <!--
    GUI\CustomControls 是指向 Macro Deck 主程序源码的符号链接，仅供 Designer 解析控件类型使用。
    其下的 .cs / .resx 等文件已由 Macro Deck 2.dll 提供，不应被本插件项目重新编译或嵌入。
  -->
  <ItemGroup>
    <Compile Remove="GUI\CustomControls\**\*.cs" />
    <EmbeddedResource Remove="GUI\CustomControls\**\*.resx" />
    <None Remove="GUI\CustomControls\**\*" />
  </ItemGroup>

  <!--
    发布后把 ExtensionManifest.json 拷贝到 publish/，并把 version 字段替换为带时间戳的 $(Version)。
    源文件 ExtensionManifest.json 保持纯版本号（1.6.5），避免每次构建污染 git 工作区。
  -->
  <Target Name="StampExtensionManifest" AfterTargets="Publish">
    <PropertyGroup>
      <_ManifestSource>$(MSBuildProjectDirectory)\ExtensionManifest.json</_ManifestSource>
      <_ManifestTarget>$(PublishDir)ExtensionManifest.json</_ManifestTarget>
    </PropertyGroup>
    <Copy SourceFiles="$(_ManifestSource)" DestinationFiles="$(_ManifestTarget)" />
    <WriteLinesToFile File="$(_ManifestTarget)"
                      Lines="$([System.Text.RegularExpressions.Regex]::Replace($([System.IO.File]::ReadAllText('$(_ManifestTarget)')), '&quot;version&quot;\s*:\s*&quot;[^&quot;]*&quot;', '&quot;version&quot; : &quot;$(Version)&quot;'))"
                      Overwrite="true" />
    <Message Importance="high" Text="ExtensionManifest.json 已生成 -> $(_ManifestTarget) (version = $(Version))" />
  </Target>

</Project>
